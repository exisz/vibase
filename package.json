{
  "name": "@exisz/agentbase",
  "version": "0.5.0",
  "description": "Agent Database — persistent state for AI agents. Multi-vendor board CLI (Trello, Markdown).",
  "main": "dist/index.js",
  "bin": {
    "agentbase": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-templates",
    "copy-templates": "mkdir -p dist/templates/builtin && cp src/templates/builtin/*.yaml dist/templates/builtin/",
    "test": "node --test dist/**/*.test.js 2>/dev/null || echo 'no tests'",
    "pretest": "npm run build",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agentbase",
    "agent",
    "database",
    "kanban",
    "board",
    "trello",
    "markdown",
    "cli",
    "ai-agent",
    "state-management",
    "dedup"
  ],
  "author": "Exis Z",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/exisz/agentbase.git"
  },
  "bugs": {
    "url": "https://github.com/exisz/agentbase/issues"
  },
  "homepage": "https://github.com/exisz/agentbase#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
